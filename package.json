{
  "name": "slack-bot-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "oxlint",
    "fmt": "oxfmt --write packages/",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev:bot": "pnpm --filter @slack-bot/bot dev",
    "dev:server": "pnpm --filter @slack-bot/server dev",
    "dev:local": "pnpm --filter @slack-bot/bot dev:local"
  },
  "devDependencies": {
    "oxlint": "^1.1.0"
  }
}
