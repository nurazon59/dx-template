    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/lib-dynamodb": "^3.1029.0",
    "@hono/node-server": "^1.14.1",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.6.2",
    "drizzle-orm": "^0.44.1",
    "hono": "^4.7.7",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
