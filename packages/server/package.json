{
  "name": "@dx-template/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @dx-template/agent build",
    "dev": "NODE_OPTIONS=--conditions=development tsx watch src/index.ts",
    "prebuild": "pnpm --filter @dx-template/agent build",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:openapi": "tsx src/scripts/generate-openapi.ts > openapi.json"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/lib-dynamodb": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@dx-template/agent": "workspace:*",
    "@dx-template/shared": "workspace:*",
    "@dx-template/workflow": "workspace:*",
    "@hono/node-server": "^1.14.1",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.10.7",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@types/json-schema": "^7.0.15",
    "better-auth": "^1.6.2",
    "drizzle-orm": "^0.44.1",
    "hono": "^4.7.7",
    "hono-openapi": "^1.3.0",
    "openapi-types": "^12.1.3",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
